generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  name         String
  role         String
  topPerformer Boolean      @default(false)
  createdAt    DateTime     @default(now())
  submissions  Submission[]
}

model Week {
  id            Int           @id
  slug          String        @unique
  title         String
  theme         String
  sessionATheme String
  sessionABody  Json
  sessionBTheme String
  sessionBBody  String
  deliverable   String
  asyncContent  String
  toolsUsed     Json
  activities    Json
  submissions   Submission[]
  liveSessions  LiveSession[]
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  weekId    Int
  type      String
  content   Json
  score     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  week      Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
}

model LiveSession {
  id              String   @id @default(cuid())
  weekId          Int
  sessionType     String
  isActive        Boolean  @default(true)
  presentationIdx Int      @default(0)
  activityTitle   String?
  activityBody    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  week            Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
}
